{
  "name": "modelhub",
  "version": "1.0.0",
  "description": "Hub unificado para múltiplos modelos de IA com API compatível OpenAI, chat integrado e gerenciamento de credenciais",
  "author": "ModelHub Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Geeks-Zone/modelhub.git"
  },
  "bugs": {
    "url": "https://github.com/Geeks-Zone/modelhub/issues"
  },
  "homepage": "https://github.com/Geeks-Zone/modelhub#readme",
  "keywords": [
    "ai",
    "llm",
    "openai",
    "anthropic",
    "google",
    "gemini",
    "chat",
    "api",
    "gateway",
    "proxy",
    "nextjs",
    "typescript",
    "prisma",
    "neon",
    "vercel"
  ],
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.18.0",
  "scripts": {
    "build": "next build",
    "build:vercel": "node scripts/vercel-build.mjs",
    "dev": "next dev",
    "lint": "eslint",
    "postinstall": "pnpm prisma:generate",
    "prisma:generate": "prisma generate --config prisma.config.ts",
    "prisma:migrate": "prisma migrate dev --config prisma.config.ts",
    "prisma:migrate:deploy": "prisma migrate deploy --config prisma.config.ts",
    "prisma:push": "prisma db push --config prisma.config.ts",
    "start": "next start",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage",
    "test:duckai-live": "node scripts/run-duckai-live-test.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.4.3",
    "@neondatabase/auth": "0.2.0-beta.1",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fast-xml-parser": "^5.3.1",
    "highlight.js": "^11.11.1",
    "hono": "^4.7.5",
    "jsdom": "^26.1.0",
    "jszip": "^3.10.1",
    "katex": "^0.16.45",
    "lucide-react": "^1.6.0",
    "next": "16.2.3",
    "next-themes": "^0.4.6",
    "pdfjs-dist": "^5.4.394",
    "pg": "^8.20.0",
    "puppeteer": "^24.40.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "shadcn": "^4.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^22.15.18",
    "@types/pg": "^8.11.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^3.2.4",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "postcss": "^8.4.49",
    "prisma": "^7.5.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
